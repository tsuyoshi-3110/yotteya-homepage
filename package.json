{
  "name": "pageit-customer-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "next dev",
    "sync:customer": "node --require tsx/cjs --import tsx/esm scripts/sync-customer-config.mjs",
    "test:customer-config": "node --require tsx/cjs --import tsx/esm --test scripts/lib/site-config-migration.test.mjs scripts/lib/domain-registry-migration.test.mjs src/lib/customer-config/resolve.test.mjs src/lib/customer-config/home-metadata.test.mjs src/lib/customer-config/site-jsonld.test.mjs src/lib/customer-config/tenant-resolver.test.mjs src/lib/customer-config/public-routes.test.mjs src/lib/customer-config/admin-domain-settings.test.mjs src/lib/customer-config/admin-domain-update.test.mjs src/lib/customer-config/admin-domain-status-sync.test.mjs src/lib/customer-config/domain-settings-view.test.mjs src/lib/customer-config/domain-settings-form.test.mjs src/lib/customer-config/domain-status-sync-view.test.mjs src/lib/customer-config/vercel-domain-client.test.mjs src/lib/customer-config/vercel-domain-status.test.mjs src/lib/customer-config/vercel-domain-status-view.test.mjs",
    "test:domain-emulator": "node --import tsx/esm scripts/run-domain-emulator-tests.mjs",
    "typecheck:customer-config": "tsc -p tsconfig.customer-config.json",
    "migrate:site-config": "node --require tsx/cjs --import tsx/esm --env-file=.env.local scripts/migrate-site-config.mjs",
    "migrate:domain-registry": "node --require tsx/cjs --import tsx/esm --env-file=.env.local scripts/migrate-domain-registry.mjs",
    "build": "npm run sync:customer && next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@googlemaps/js-api-loader": "^1.16.10",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "firebase": "^11.9.1",
    "firebase-admin": "^13.4.0",
    "framer-motion": "^12.23.24",
    "googleapis": "^154.1.0",
    "heic2any": "^0.0.4",
    "jotai": "^2.12.5",
    "libphonenumber-js": "^1.12.9",
    "next": "^16.1.1",
    "nodemailer": "^7.0.5",
    "openai": "^5.23.2",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-color": "^2.19.3",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.1",
    "react-hook-form": "^7.62.0",
    "react-intersection-observer": "^9.16.0",
    "react-qr-code": "^2.0.18",
    "react-swipeable-list": "^1.10.0",
    "recharts": "^3.3.0",
    "stripe": "^18.3.0",
    "tailwind-merge": "^3.3.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "lucide-react": "^0.525.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5"
  }
}
